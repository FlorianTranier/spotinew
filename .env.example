# ============================================================
# spotinew — exemple de configuration
# Copie ce fichier en « .env » et remplis les valeurs.
# Le fichier .env ne doit JAMAIS être committé (voir .gitignore).
# ============================================================

# --- Identifiants de l'app Spotify (Developer Dashboard) ---
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# URL de redirection déclarée dans le dashboard Spotify.
# Spotify impose 127.0.0.1 (et non localhost) pour le loopback.
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Refresh token obtenu via `python src/auth_setup.py` (étape unique).
SPOTIFY_REFRESH_TOKEN=

# --- Configuration de la synchronisation ---
# Date plancher : seules les sorties parues à partir de cette date sont ajoutées.
START_DATE=2026-01-01

# Nom de la playlist cible. Si elle n'existe pas, elle est créée automatiquement.
SPOTIFY_PLAYLIST_NAME=Nouveautés abonnements

# Optionnel : cibler une playlist précise par son ID (prioritaire sur le nom).
# SPOTIFY_PLAYLIST_ID=
